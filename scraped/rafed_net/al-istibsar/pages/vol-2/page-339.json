  "paragraphs": [
    "ص",
    "العنوان",
    "عدد الحاديث",
    "٧٣",
    "باب حكم الهلال إذا رؤي\nقبل الزوال أو بعده",
    "٧",
    "٧٥",
    "باب حكم الهلال إذا غاب\nقبل الشفق أو بعده",
    "٢",
    "٧٦",
    "باب ذكر جمل من الاخبار\nيتعلق بها أصحاب العدد",
    "٤",
    "٧٧",
    "باب صيام يوم الشك",
    "١٠",
    "أبواب ما ينقض الصيام",
    "٨٠",
    "باب حكم الجماع",
    "٦",
    "٨٢",
    "باب حكم القبلة للصائم",
    "٣",
    "٨٢",
    "باب حكم من أمذى وهو\nصائم",
    "٣",
    "٨٣",
    "باب حكم الاحتقان",
    "٢",
    "٨٤",
    "باب حكم الارتماس في\nالماء",
    "٦",
    "٨٥",
    "باب حكم من أصبح جنبا\nفي شهر رمضان",
    "١٤",
    "٨٩",
    "باب حكم الكحل للصائم",
    "٨",
    "٩٠",
    "باب الحجامة للصائم",
    "٥",
    "٩١",
    "باب السواك للصائم بالرطب\nواليابس",
    "٥",
    "٩٢",
    "باب شم الريحان للصائم",
    "٧",
    "٩٤",
    "باب حكم المضمضة والاستنشاق",
    "٣",
    "٩٥",
    "باب ما يجوز للطباخ أن\nيذوق من الطعام",
    "٤",
    "٩٥",
    "باب كفارة من أفطر يوما\nمن شهر رمضان",
    "٧",
    "أبواب أحكام المسافرين",
    "٩٨",
    "باب حكم من خرج إلى السفر\nبعد طلوع الفجر ولم يكن يبيت بنية السفر",
    "٨"
  ]
