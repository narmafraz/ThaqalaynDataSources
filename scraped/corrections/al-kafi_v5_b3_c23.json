        "verses": [
            {
                "local_index": 1,
                "part_type": "Hadith",
                "path": "/books/al-kafi:5:3:23:1",
                "text": [
                    "عَلِيُّ بْنُ إِبْرَاهِيمَ عَنْ أَبِيهِ عَنِ ابْنِ أَبِي عُمَيْرٍ عَنْ هِشَامِ بْنِ سَالِمٍ وَحَمَّادٍ عَنْ زُرَارَةَ عَنْ أَبِي عَبْدِ اللهِ (عَلَيْهِ السَّلام) فِي تَزْوِيجِ أُمِّ كُلْثُومٍ فَقَالَ إِنَّ ذَلِكَ فَرْجٌ غُصِبْنَاهُ."
                ],
                "translations": {
                }
            },
            {
                "local_index": 2,
                "part_type": "Hadith",
                "path": "/books/al-kafi:5:3:23:2",
                "text": [
                    "مُحَمَّدُ بْنُ أَبِي عُمَيْرٍ عَنْ هِشَامِ بْنِ سَالِمٍ عَنْ أَبِي عَبْدِ اللهِ (عَلَيْهِ السَّلام) قَالَ لَمَّا خَطَبَ إِلَيْهِ قَالَ لَهُ أَمِيرُ الْمُؤْمِنِينَ إِنَّهَا صَبِيَّةٌ قَالَ فَلَقِيَ الْعَبَّاسَ فَقَالَ لَهُ مَإ؛ لِي أَبِي بَأْسٌ قَالَ وَمَا ذَاكَ قَالَ خَطَبْتُ إِلَى ابْنِ أَخِيكَ فَرَدَّنِي أَمَا وَاللهِ لأعَوِّرَنَّ زَمْزَمَ وَلا أَدَعُ لَكُمْ مَكْرُمَةً إِلا هَدَمْتُهَا وَلأقِيمَنَّ عَلَيْهِ شَاهِدَيْنِ بِأَنَّهُ سَرَقَ وَلأقْطَعَنَّ يَمِينَهُ فَأَتَاهُ الْعَبَّاسُ فَأَخْبَرَهُ وَسَأَلَهُ أَنْ يَجْعَلَ الأمْرَ إِلَيْهِ فَجَعَلَهُ إِلَيْهِ. "
                ],
                "translations": {
                }
           }
        ]
