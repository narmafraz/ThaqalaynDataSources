    { "phrase_ar": "وَالْعَصْرِ إِنَّ الْإِنْسَانَ لَفِي خُسْرٍ", "phrase_en": "By time, indeed mankind is in loss", "category": "quranic_echo" },
    { "phrase_ar": "إِنَّ مَعَ الْعُسْرِ يُسْرًا", "phrase_en": "Indeed with hardship comes ease", "category": "quranic_echo" },
    { "phrase_ar": "فَاذْكُرُونِي أَذْكُرْكُمْ", "phrase_en": "Remember Me and I will remember you", "category": "quranic_echo" },
    { "phrase_ar": "وَمَنْ يَتَّقِ اللَّهَ يَجْعَلْ لَهُ مَخْرَجًا", "phrase_en": "Whoever fears Allah, He will make a way out for him", "category": "quranic_echo" },
    { "phrase_ar": "إِنَّ اللَّهَ مَعَ الصَّابِرِينَ", "phrase_en": "Indeed Allah is with the patient", "category": "quranic_echo" },
    { "phrase_ar": "وَلَا تَيْأَسُوا مِنْ رَوْحِ اللَّهِ", "phrase_en": "Do not despair of the mercy of Allah", "category": "quranic_echo" },
    { "phrase_ar": "يَا أَيُّهَا الَّذِينَ آمَنُوا", "phrase_en": "O you who believe", "category": "quranic_echo" },
    { "phrase_ar": "وَقُلْ رَبِّ زِدْنِي عِلْمًا", "phrase_en": "And say: My Lord, increase me in knowledge", "category": "quranic_echo" },
    { "phrase_ar": "ادْعُونِي أَسْتَجِبْ لَكُمْ", "phrase_en": "Call upon Me, I will respond to you", "category": "quranic_echo" },
    { "phrase_ar": "إِنَّمَا يُرِيدُ اللَّهُ لِيُذْهِبَ عَنْكُمُ الرِّجْسَ أَهْلَ الْبَيْتِ", "phrase_en": "Allah only intends to remove impurity from you, O People of the House", "category": "quranic_echo" },
    { "phrase_ar": "كُنْتُمْ خَيْرَ أُمَّةٍ أُخْرِجَتْ لِلنَّاسِ", "phrase_en": "You are the best nation brought forth for mankind", "category": "quranic_echo" },
    { "phrase_ar": "حَقُّ اللَّهِ عَلَى الْعِبَادِ", "phrase_en": "The right of Allah upon His servants", "category": "theological_concept" },
