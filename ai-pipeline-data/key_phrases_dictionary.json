    { "phrase_ar": "الْحَيَاءُ مِنَ الْإِيمَانِ", "phrase_en": "Modesty is from faith", "category": "well_known_saying" },
    { "phrase_ar": "الْمُسْلِمُ مَنْ سَلِمَ الْمُسْلِمُونَ مِنْ لِسَانِهِ وَيَدِهِ", "phrase_en": "A Muslim is one from whose tongue and hand other Muslims are safe", "category": "well_known_saying" },
    { "phrase_ar": "الدِّينُ النَّصِيحَةُ", "phrase_en": "Religion is sincere advice", "category": "well_known_saying" },
    { "phrase_ar": "كُلُّكُمْ رَاعٍ وَكُلُّكُمْ مَسْئُولٌ عَنْ رَعِيَّتِهِ", "phrase_en": "Each of you is a shepherd and each is responsible for his flock", "category": "well_known_saying" },
    { "phrase_ar": "لَا يُؤْمِنُ أَحَدُكُمْ حَتَّىٰ يُحِبَّ لِأَخِيهِ مَا يُحِبُّ لِنَفْسِهِ", "phrase_en": "None of you truly believes until he loves for his brother what he loves for himself", "category": "well_known_saying" },
    { "phrase_ar": "الْمُسْلِمُونَ عِنْدَ شُرُوطِهِمْ", "phrase_en": "Muslims are bound by their conditions/contracts", "category": "jurisprudential_term" },
    { "phrase_ar": "الْبَيِّنَةُ عَلَى الْمُدَّعِي وَالْيَمِينُ عَلَى الْمُدَّعَىٰ عَلَيْهِ", "phrase_en": "The burden of proof is on the claimant and the oath on the defendant", "category": "jurisprudential_term" },
    { "phrase_ar": "لَا طَاعَةَ لِمَخْلُوقٍ فِي مَعْصِيَةِ الْخَالِقِ", "phrase_en": "No obedience to a creature in disobedience to the Creator", "category": "well_known_saying" },
    { "phrase_ar": "النَّاسُ سَوَاسِيَةٌ كَأَسْنَانِ الْمُشْطِ", "phrase_en": "People are equal like the teeth of a comb", "category": "well_known_saying" },
    { "phrase_ar": "أُمَّةٌ وَسَطًا", "phrase_en": "A moderate/just nation", "category": "quranic_echo" },
    { "phrase_ar": "شَهِدَ اللَّهُ أَنَّهُ لَا إِلٰهَ إِلَّا هُوَ", "phrase_en": "Allah bears witness that there is no god but He", "category": "quranic_echo" },
    { "phrase_ar": "كُلُّ نَفْسٍ ذَائِقَةُ الْمَوْتِ", "phrase_en": "Every soul shall taste death", "category": "quranic_echo" },
    { "phrase_ar": "وَمَا خَلَقْتُ الْجِنَّ وَالْإِنْسَ إِلَّا لِيَعْبُدُونِ", "phrase_en": "I did not create jinn and mankind except to worship Me", "category": "quranic_echo" },
    { "phrase_ar": "إِنَّ اللَّهَ لَا يُغَيِّرُ مَا بِقَوْمٍ حَتَّىٰ يُغَيِّرُوا مَا بِأَنْفُسِهِمْ", "phrase_en": "Allah does not change the condition of a people until they change what is in themselves", "category": "quranic_echo" },
    { "phrase_ar": "وَتَعَاوَنُوا عَلَى الْبِرِّ وَالتَّقْوَىٰ", "phrase_en": "Cooperate in righteousness and piety", "category": "quranic_echo" },
    { "phrase_ar": "لَيْلَةُ الْقَدْرِ خَيْرٌ مِنْ أَلْفِ شَهْرٍ", "phrase_en": "The Night of Decree is better than a thousand months", "category": "quranic_echo" },
    { "phrase_ar": "يَوْمُ الْعَدْلِ عَلَى الظَّالِمِ أَشَدُّ مِنْ يَوْمِ الْجَوْرِ عَلَى الْمَظْلُومِ", "phrase_en": "A day of justice for the oppressor is harder than a day of injustice for the oppressed", "category": "well_known_saying" },
    { "phrase_ar": "الْعَدْلُ أَسَاسُ الْمُلْكِ", "phrase_en": "Justice is the foundation of governance", "category": "well_known_saying" }
