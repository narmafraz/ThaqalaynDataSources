        "es": "el amor apasionado (al-'ishq)",
        "fr": "l'amour passionné (al-'ishq)",
        "de": "die leidenschaftliche Liebe (al-'Ishq)",
        "ru": "страстная любовь (аль-ишк)",
        "zh": "热恋（伊什格）"
      },
