      "translation": {
        "en": "the whole year/eternity",
        "ur": "پوری زندگی / سارا سال",
        "tr": "senenin tamamı",
        "fa": "تمام روزگار",
        "id": "sepanjang masa",
        "bn": "সারা বছর",
        "es": "toda la vida",
        "fr": "toute une vie",
