  "translations": {
    "en": "about the words of Allah, Mighty and Majestic: 'Fear Allah and be with the truthful ones' [9:119]",
    "ur": "اللہ عزوجل کے اس قول کے بارے میں: 'اللہ سے ڈرو اور صادقین کے ساتھ رہو' [9:119]",
    "tr": "'Allah'tan sakının ve sadıklarla birlikte olun' [9:119] ilahi buyruğu hakkında",
    "fa": "درباره سخن خداوند عزوجل: «از خدا بترسید و با صادقین باشید» [9:119]",
    "id": "tentang firman Allah Azza wa Jalla: 'Bertakwalah kepada Allah dan jadilah bersama orang-orang yang benar' [9:119]",
    "bn": "আল্লাহ আয্যা ওয়াজাল্লার এই বাণী সম্পর্কে: 'আল্লাহকে ভয় কর এবং সত্যবাদীদের সাথে থাকো' [৯:১১৯]",
    "es": "acerca de las palabras de Allah, Poderoso y Majestuoso: 'Temed a Allah y sed con los veraces' [9:119]",
    "fr": "à propos de la parole d'Allah, Puissant et Majestueux : 'Craignez Allah et soyez avec les véridiques' [9:119]",
    "de": "über die Worte Allahs, des Mächtigen und Majestätischen: 'Fürchtet Allah und seid mit den Wahrhaftigen' [9:119]",
    "ru": "о словах Аллаха, Великого и Могущественного: «Бойтесь Аллаха и будьте вместе с правдивыми» [9:119]",
    "zh": "关于真主——尊贵威严的——的话语：\"敬畏真主，与诚实者同在\"[9:119]"
  }
