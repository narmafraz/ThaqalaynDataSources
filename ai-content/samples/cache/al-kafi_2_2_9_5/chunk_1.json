    {
      "word": "السَّحَابُ",
      "translation": {
        "en": "the clouds",
        "ur": "بادل",
        "tr": "bulutlar",
        "fa": "ابرها",
        "id": "awan-awan",
        "bn": "মেঘ",
        "es": "las nubes",
        "fr": "les nuages",
