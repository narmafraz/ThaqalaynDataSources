    {
      "word": "الْمِيثَاقَ",
      "translation": {
        "en": "the covenant",
        "ur": "میثاق/عہد",
        "tr": "misakı/ahdi",
        "fa": "میثاق را",
        "id": "perjanjian itu",
        "bn": "সেই প্রতিশ্রুতি",
        "es": "el pacto",
