        "key_terms": {
          "الجنة": "جنت -- آخرت میں نیکوکاروں کا مقام",
          "شيعتنا": "ہمارے شیعہ -- اہل بیت کے پیروکار",
          "أهل البيت": "اہل بیت -- نبی کا گھرانہ"
