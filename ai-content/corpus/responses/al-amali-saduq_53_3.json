    "chunks": [
      {
        "chunk_type": "isnad",
        "word_start": 0,
        "word_end": 12,
        "translations": {
          "en": "By this chain of narration, the Messenger of Allah (may Allah bless him and his family) said:",
          "ur": "اور اسی سند سے، رسول اللہ (صلی اللہ علیہ وآلہ) نے فرمایا:",
          "tr": "Aynı isnad ile, Resulullah (s.a.a.) buyurdu:",
          "fa": "و با همین اسناد، رسول خدا (صلی الله علیه وآله) فرمود:",
          "id": "Dengan sanad yang sama, Rasulullah (s.a.w.) bersabda:",
          "bn": "একই সনদে, রাসূলুল্লাহ (স.) বলেছেন:",
