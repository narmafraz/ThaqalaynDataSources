    "translations": {
      "en": {
        "summary": "The Prophet Muhammad (peace be upon him and his family) taught that the way to atone for backbiting (ghibah) is to pray to God seeking forgiveness on behalf of the person one has spoken ill about. This hadith, narrated through a chain going back to the companion Anas ibn Malik, addresses the widespread social sin of backbiting by prescribing a specific spiritual remedy that counteracts the harm done.",
        "key_terms": {
          "كفارة": "Expiation, atonement, penance for a sin",
          "الاغتياب": "Backbiting (ghibah), speaking ill of someone in their absence",
          "تستغفر": "To seek forgiveness from God (istighfar)"
        },
        "seo_question": "What is the expiation for backbiting in Islam?"
      },
      "ur": {
        "summary": "نبی کریم صلی اللہ علیہ وآلہ وسلم نے فرمایا کہ غیبت کا کفارہ یہ ہے کہ جس شخص کی غیبت کی ہو اس کے لیے اللہ سے مغفرت طلب کرو۔ یہ حدیث صحابی انس بن مالک کے ذریعے روایت ہوئی ہے۔",
        "key_terms": {
          "كفارة": "کفارہ، گناہ کا فدیہ",
          "الاغتياب": "غیبت، کسی کی عدم موجودگی میں برا بھلا کہنا",
          "تستغفر": "استغفار کرنا، اللہ سے معافی مانگنا"
        },
        "seo_question": "اسلام میں غیبت کا کفارہ کیا ہے؟"
      },
      "tr": {
        "summary": "Hz. Peygamber (s.a.v.s.) gıybetin kefaretinin, gıybetini yapılan kişi için Allah'tan af dileme olduğunu bildirmiştir. Bu hadis, sahabi Enes bin Malik kanalıyla rivayet edilmiştir.",
        "key_terms": {
          "كفارة": "Kefaret, günahın bedeli",
          "الاغتياب": "Gıybet, bir kişinin arkasından kötü konuşmak",
          "تستغفر": "İstiğfar etmek, Allah'tan bağışlanma dilemek"
        },
        "seo_question": "İslam'da gıybetin kefareti nedir?"
      },
      "fa": {
        "summary": "پیامبر اکرم صلی الله علیه وآله وسلم فرمودند که کفاره غیبت آن است که برای شخصی که از او غیبت کرده‌ای از خداوند طلب آمرزش کنی. این حدیث از طریق صحابی انس بن مالک روایت شده است.",
        "key_terms": {
          "كفارة": "کفاره، جبران گناه",
          "الاغتياب": "غیبت، بدگویی پشت سر کسی",
          "تستغفر": "استغفار کردن، طلب آمرزش از خدا"
        },
        "seo_question": "کفاره غیبت در اسلام چیست؟"
      },
      "id": {
        "summary": "Nabi Muhammad SAW mengajarkan bahwa kafarah (tebusan) untuk ghibah (menggunjing) adalah dengan memohonkan ampun kepada Allah bagi orang yang digunjingkan. Hadis ini diriwayatkan melalui sahabat Anas bin Malik.",
        "key_terms": {
          "كفارة": "Kafarah, tebusan dosa",
          "الاغتياب": "Ghibah, menggunjing orang di belakangnya",
          "تستغفر": "Istighfar, memohon ampun kepada Allah"
        },
        "seo_question": "Apa kafarah untuk ghibah dalam Islam?"
      },
      "bn": {
        "summary": "নবী মুহাম্মাদ (সা.) শিক্ষা দিয়েছেন যে গীবতের কাফফারা হলো যার সম্পর্কে গীবত করা হয়েছে তার জন্য আল্লাহর কাছে ক্ষমা চাওয়া। এই হাদীসটি সাহাবী আনাস ইবনে মালিকের সূত্রে বর্ণিত।",
        "key_terms": {
          "كفارة": "কাফফারা, পাপের প্রায়শ্চিত্ত",
          "الاغتياب": "গীবত, কারো অনুপস্থিতিতে তার নিন্দা করা",
          "تستغفر": "ইস্তিগফার, আল্লাহর কাছে ক্ষমা চাওয়া"
        },
        "seo_question": "ইসলামে গীবতের কাফফারা কী?"
      },
      "es": {
        "summary": "El Profeta Muhammad (la paz sea con él y su familia) enseñó que la expiación por la murmuración (ghibah) es pedir perdón a Dios por la persona de la que se ha hablado mal. Este hadiz fue narrado a través del compañero Anas ibn Malik.",
        "key_terms": {
          "كفارة": "Expiación, compensación por un pecado",
          "الاغتياب": "Murmuración (ghibah), hablar mal de alguien en su ausencia",
          "تستغفر": "Pedir perdón a Dios (istighfar)"
        },
        "seo_question": "¿Cuál es la expiación por la murmuración en el Islam?"
