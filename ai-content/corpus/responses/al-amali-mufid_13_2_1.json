    "translations": {
      "en": {
        "summary": "This prophetic hadith extols the virtues of Ramadan. The Prophet describes it as a blessed month with obligatory fasting, opened gates of Paradise, shackled devils, and Laylat al-Qadr which is better than a thousand months.",
        "key_terms": {
          "شَهْرُ رَمَضَانَ": "Month of Ramadan",
          "لَيْلَةٌ خَيْرٌ مِنْ أَلْفِ شَهْرٍ": "A night better than a thousand months: Laylat al-Qadr",
          "أَبْوَابُ الْجِنَانِ": "Gates of Paradise"
        },
        "seo_question": "What did the Prophet say about the blessings of Ramadan?"
      },
      "ur": {
        "summary": "یہ حدیث ماہ رمضان کی فضیلت بیان کرتی ہے۔",
        "key_terms": {
          "شَهْرُ رَمَضَانَ": "ماہ رمضان",
          "لَيْلَةٌ خَيْرٌ مِنْ أَلْفِ شَهْرٍ": "شب قدر"
        },
        "seo_question": "نبی نے ماہ رمضان کی فضیلت کیا بیان فرمائی؟"
      },
      "tr": {
        "summary": "Bu hadis Ramazan ayinin faziletlerini anlatir.",
        "key_terms": {
          "شَهْرُ رَمَضَانَ": "Ramazan ayi",
          "لَيْلَةٌ خَيْرٌ مِنْ أَلْفِ شَهْرٍ": "Kadir Gecesi"
        },
        "seo_question": "Hz. Peygamber Ramazan hakkinda ne buyurmustur?"
      },
      "fa": {
        "summary": "این حدیث فضایل ماه رمضان را بیان می‌کند.",
        "key_terms": {
          "شَهْرُ رَمَضَانَ": "ماه رمضان",
          "لَيْلَةٌ خَيْرٌ مِنْ أَلْفِ شَهْرٍ": "شب قدر"
        },
        "seo_question": "پیامبر درباره فضایل رمضان چه فرمود؟"
      },
      "id": {
        "summary": "Hadis ini menerangkan keutamaan bulan Ramadhan.",
        "key_terms": {
          "شَهْرُ رَمَضَانَ": "Bulan Ramadhan",
          "لَيْلَةٌ خَيْرٌ مِنْ أَلْفِ شَهْرٍ": "Lailatul Qadr"
        },
        "seo_question": "Apa keutamaan bulan Ramadhan menurut Nabi?"
