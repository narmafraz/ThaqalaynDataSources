    "translations": {
      "en": {
        "summary": "Imam Ja'far al-Sadiq (AS) identifies three uniquely sacred things in God's creation that have no equal: the Quran (God's wisdom and light), the Ka'ba (the divinely-appointed direction of prayer from which no deviation is accepted), and the Prophet's household (Ahl al-Bayt). This triad - Scripture, Sacred House, and Prophetic Progeny - represents the three pillars of divine guidance in Shia theology, paralleling the hadith of the Two Weighty Things (al-Thaqalayn).",
        "key_terms": {
          "حرمات": "Hurumat - hallowed/sacred things, sanctities that must be respected and not violated",
          "كتابه": "His Book - the Quran, described as God's wisdom (hikma) and light (nur)",
          "بيته": "His House - the Ka'ba in Mecca, the direction of prayer (qibla)",
          "عترة": "'Itra - the progeny/household of the Prophet, a key concept in Shia Islam"
        },
        "seo_question": "What are the three most sacred things according to Imam al-Sadiq?"
      },
      "ur": {
        "summary": "امام جعفر صادق علیہ السلام نے فرمایا کہ اللہ تعالیٰ کی تین بے مثال حرمتیں ہیں: قرآن (اللہ کی حکمت و نور)، کعبہ (قبلہ جس سے انحراف ناقابل قبول ہے)، اور نبی اکرم کی عترت۔ یہ شیعہ عقیدے میں ہدایت الٰہی کے تین ستون ہیں۔",
        "key_terms": {
          "حرمات": "حرمتیں - مقدس اور محترم چیزیں",
          "كتابه": "اس کی کتاب - قرآن، اللہ کی حکمت اور نور",
          "بيته": "اس کا گھر - مکہ میں کعبہ",
          "عترة": "عترت - نبی اکرم کی اولاد و اہل بیت"
        },
        "seo_question": "امام صادق کے مطابق اللہ کی تین مقدس ترین چیزیں کون سی ہیں؟"
      },
      "tr": {
        "summary": "İmam Ca'fer es-Sadık (a.s.) Allah'ın eşi benzeri olmayan üç kutsallığını açıklamıştır: Kur'an (hikmet ve nur), Kâbe (kıble) ve Hz. Peygamber'in Ehlibeyt'i. Bu üçlü, Şia inancında ilahi hidayetin temel direklerini oluşturur.",
        "key_terms": {
          "حرمات": "Hürmetler - kutsal ve dokunulmaz şeyler",
          "كتابه": "Kitabı - Kur'an, Allah'ın hikmeti ve nuru",
          "بيته": "Evi - Mekke'deki Kâbe",
