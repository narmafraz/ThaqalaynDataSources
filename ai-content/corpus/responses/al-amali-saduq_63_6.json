    "translations": {
      "en": {
        "summary": "Imam al-Sadiq (AS) teaches that when a worshiper calls upon Allah with three divine appellations while prostrating - 'O Allah, O my Lord, O my Master' - three times, Allah personally responds with 'Here I am, My servant, ask for your need.' This was taught in the context of encouraging intimate supplication during sajdah, the position of closest proximity to God.",
        "key_terms": {
          "ساجد": "One in prostration (sujud) - the closest position to God in prayer",
          "لبيك": "Here I am - Allah's direct response to the supplicant",
          "حاجتك": "Your need - whatever the servant requires from Allah"
        },
        "seo_question": "What supplication should be said in prostration according to Imam al-Sadiq?"
      },
      "ur": {
        "summary": "امام صادق علیہ السلام نے فرمایا سجدے میں تین مرتبہ یا اللہ یا رب یا سید کہنے پر اللہ لبیک کہتا ہے۔",
        "key_terms": {
          "ساجد": "سجدے کی حالت",
          "لبيك": "لبیک - حاضر ہوں",
          "حاجتك": "تیری حاجت"
        },
        "seo_question": "سجدے میں کون سی دعا پڑھنی چاہیے؟"
      },
      "tr": {
        "summary": "İmam Sadık (a.s.) secdede üç kez bu duayı okumanın Allah'ın doğrudan cevabını getirdiğini öğretmiştir.",
