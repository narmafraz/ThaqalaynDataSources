    "translations": {
      "en": {
        "summary": "Imam al-Sadiq (AS) teaches that a believer who dies in the blessed period between midday Thursday and midday Friday receives divine protection from the torment of the grave. This teaching reflects the special sanctity of Friday (Jumu'ah) in Islam, which extends backward into Thursday afternoon, a time traditionally associated with increased blessings. The 'pressure of the grave' (daghtat al-qabr) is a well-known concept in Islamic eschatology referring to the initial constriction the deceased experiences in the grave.",
        "key_terms": {
          "زوال الشمس": "The decline of the sun from its zenith, marking the onset of the noon (Dhuhr) prayer time",
          "ضغطة القبر": "The pressure/squeezing of the grave — an eschatological trial that the deceased faces after burial"
        },
        "seo_question": "What is the significance of dying between Thursday midday and Friday midday in Shia Islam?"
      },
      "ur": {
        "summary": "امام صادق (علیہما السلام) نے فرمایا کہ جو مؤمن جمعرات کی دوپہر سے جمعہ کی دوپہر کے درمیان فوت ہو جائے، اللہ تعالیٰ اسے فشار قبر سے محفوظ رکھے گا۔ یہ تعلیم جمعہ کے دن کی خاص فضیلت اور برکت کی عکاسی کرتی ہے۔",
        "key_terms": {
          "زوال الشمس": "سورج کا زوال، یعنی نصف النہار کے بعد سورج کا ڈھلنا، نماز ظہر کے وقت کی ابتداء",
          "ضغطة القبر": "فشار قبر — قبر میں ہونے والا ابتدائی عذاب جو عالم برزخ کی آزمائش ہے"
