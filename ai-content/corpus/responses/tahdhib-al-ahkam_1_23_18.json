    "chunks": [
      {
        "chunk_type": "isnad",
        "translations": {
          "en": "Muḥammad ibn ʿAlī ibn Maḥbūb, from Muʿāwiyah ibn Ḥukaym, from ʿAbd Allāh ibn al-Mughīrah, from Ibn Bukayr, from Zurārah, from Abū Jaʿfar عليه السلام, who said:",
          "ur": "",
          "tr": "",
          "fa": "",
          "id": "",
          "bn": "",
          "es": "",
          "fr": "",
          "de": "",
          "ru": "",
          "zh": ""
        },
        "word_start": 0,
        "word_end": 25,
        "arabic_text": "مُحَمَّدُ بْنُ عَلِيِّ بْنِ مَحْبُوبٍ عَنْ مُعَاوِيَةَ بْنِ حُكَيْمٍ عَنْ عَبْدِ اللَّهِ بْنِ الْمُغِيرَةِ عَنِ ابْنِ بُكَيْرٍ عَنْ زُرَارَةَ عَنْ أَبِي جَعْفَرٍ عَلَيْهِ السَّلَامُ قَالَ"
      },
      {
        "chunk_type": "body",
        "translations": {
          "en": "If snow afflicts him, then let him look to the felt of his saddle and perform tayammum from its dust, or from something with him. And if he is in a state where he finds nothing but clay, then there is no harm in performing tayammum from it.",
          "ur": "",
          "tr": "",
          "fa": "",
          "id": "",
          "bn": "",
          "es": "",
          "fr": "",
          "de": "",
          "ru": "",
          "zh": ""
        },
        "word_start": 25,
        "word_end": 51,
        "arabic_text": "إِنْ أَصَابَهُ الثَّلْجُ فَلْيَنْظُرْ لِبْدَ سَرْجِهِ فَيَتَيَمَّمُ مِنْ غُبَارِهِ، أَوْ مِنْ شَيْءٍ مَعَهُ، وَإِنْ كَانَ فِي حَالٍ لَا يَجِدُ إِلَّا الطِّينَ فَلَا بَأْسَ أَنْ يَتَيَمَّمَ مِنْهُ."
      }
    ],
    "translations": {
      "en": {
        "summary": "This hadith gives a legal ruling for tayammum when ordinary earth or dust is not readily available due to snow or difficult conditions. It permits using the dust on the felt of a saddle or, if nothing else is found, even clay, showing facilitation in acts of ritual purity.",
        "seo_question": "Can tayammum be performed with dust from a saddle or with clay when snow prevents access to normal earth?",
        "key_terms": {
