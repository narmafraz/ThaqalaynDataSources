    "translations": {
      "en": {
        "summary": "Imam al-Sadiq (peace be upon him) quotes a teaching that a servant who restrains himself for the sake of God will be rewarded with entry into Paradise. This short hadith emphasizes self-discipline and controlling one's desires as a path to divine reward, reflecting the broader ethical emphasis on nafs (self) purification in Shia tradition.",
        "key_terms": {
          "يحبس نفسه": "Restrains himself - the act of controlling one's temptations and desires",
          "على الله": "For the sake of God - dedicating self-restraint to divine obedience",
          "الجنة": "Paradise - the ultimate reward for those who practice self-control"
        },
        "seo_question": "What is the reward for controlling one's temptations according to Imam al-Sadiq?"
      },
      "ur": {
        "summary": "امام صادق علیہ السلام سے روایت ہے کہ جو بندہ اللہ کی خاطر اپنے نفس کو روکے، اللہ اسے جنت میں داخل کرے گا۔ یہ حدیث نفس کی اصلاح اور خواہشات پر قابو پانے کی فضیلت بیان کرتی ہے۔",
        "key_terms": {
          "يحبس نفسه": "اپنے نفس کو روکنا - خواہشات پر قابو پانا",
          "على الله": "اللہ کی خاطر - خدائی اطاعت کے لیے",
          "الجنة": "جنت - ضبط نفس کا اجر"
        },
        "seo_question": "امام صادق کے مطابق خواہشات پر قابو پانے کا اجر کیا ہے؟"
      },
      "tr": {
        "summary": "İmam Sâdık (a.s.) şöyle buyurmuştur: Bir kul nefsini Allah için tutarsa, Allah onu cennete koyar. Bu hadis, nefis terbiyesinin ve arzuları kontrol etmenin önemini vurgular.",
        "key_terms": {
          "يحبس نفسه": "Nefsini tutmak - arzularını kontrol etmek",
          "على الله": "Allah için - ilâhî itaat uğruna",
          "الجنة": "Cennet - nefis kontrolünün mükâfatı"
        },
        "seo_question": "İmam Sâdık'a göre nefsini kontrol edenin mükâfatı nedir?"
      },
      "fa": {
        "summary": "امام صادق علیهما السلام فرمود: بنده‌ای نیست که نفس خود را برای خدا بازدارد مگر آن‌که خداوند او را به بهشت داخل کند. این حدیث بر اهمیت مهار نفس و خویشتن‌داری تأکید دارد.",
        "key_terms": {
          "يحبس نفسه": "نفس خود را بازداشتن - مهار خواهش‌ها",
          "على الله": "برای خدا - در راه اطاعت الهی",
