    "translations": {
      "en": {
        "summary": "Imam al-Sadiq (peace be upon him) teaches that a true believer needs no worldly retaliation against his enemies, for the greatest divine support is witnessing one's adversary engaged in sin against God. This teaching was delivered in the context of encouraging believers to maintain moral composure when wronged, reminding them that an enemy's sinfulness is itself a sign of their own spiritual defeat.",
        "key_terms": {
          "حسب": "Sufficient, enough — indicates that divine support takes many forms",
          "نصرة": "Victory, divine support — God's aid for the believer",
          "معاصي": "Sins, acts of disobedience against God's commands"
        },
        "seo_question": "What did Imam al-Sadiq say about the believer and their enemy?"
      },
      "ur": {
        "summary": "امام صادق علیہ السلام نے فرمایا کہ مومن کے لیے خدا کی نصرت یہی کافی ہے کہ اس کا دشمن گناہوں میں مبتلا ہو۔ یہ تعلیم مومنین کو صبر اور اخلاقی برتری کی یاد دلاتی ہے۔",
        "key_terms": {
          "حسب": "کافی، بس — مومن کے لیے کفایت",
          "نصرة": "نصرت، مدد — اللہ کی مدد",
          "معاصي": "گناہ، نافرمانیاں"
        },
        "seo_question": "امام صادق نے مومن کے دشمن کے بارے میں کیا فرمایا؟"
      },
      "tr": {
