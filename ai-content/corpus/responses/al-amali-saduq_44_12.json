    "translations": {
      "en": {
        "summary": "Imam Ja'far al-Sadiq (AS) teaches a supplication of gratitude to be recited silently when encountering someone with a physical disability or affliction. The teaching emphasizes both gratitude for one's own wellbeing and sensitivity toward the afflicted person by requiring it be said privately. This was guidance given during the second century AH, addressing the social etiquette of how believers should respond to seeing suffering -- not with pity that might embarrass the person, but with private thankfulness to God and recognition that all conditions are by divine will.",
        "key_terms": {
          "عاهة": "Physical disability, bodily defect, chronic affliction",
          "مثل به": "One who has been mutilated or disfigured",
          "بلاء": "Affliction, trial, calamity sent as a test from God",
          "عافاني": "Granted me wellness/safety, spared me from affliction"
        },
        "seo_question": "What supplication should one say when seeing a person with a disability or affliction in Islam?"
      },
      "ur": {
        "summary": "امام جعفر صادق علیہ السلام نے ایک دعا تعلیم فرمائی جو کسی معذور یا مصیبت زدہ شخص کو دیکھتے وقت خاموشی سے پڑھی جائے۔ یہ حدیث عافیت پر شکر اور مبتلا شخص کے احساسات کی پاسداری دونوں سکھاتی ہے۔",
        "key_terms": {
          "عاهة": "جسمانی معذوری، عیب، دائمی بیماری",
          "بلاء": "آزمائش، مصیبت، الہٰی امتحان",
          "عافاني": "مجھے عافیت دی، تندرستی عطا کی"
        },
        "seo_question": "اسلام میں کسی معذور شخص کو دیکھ کر کیا دعا پڑھنی چاہیے؟"
      },
      "tr": {
        "summary": "İmam Cafer es-Sadık (a.s.) engelli veya musibete uğramış birini gören kimsenin gizlice okuması gereken bir dua öğretmiştir. Bu hadis hem nimete şükrü hem de muzdarip kişinin duygularına saygı göstermeyi vurgular.",
        "key_terms": {
          "عاهة": "Engellilik, bedensel kusur",
          "بلاء": "Bela, musibet, ilahi imtihan",
          "عافاني": "Bana afiyet verdi, sağlık ihsan etti"
        },
        "seo_question": "İslam'da engelli birini gördüğümüzde hangi duayı okumamız gerekir?"
      },
      "fa": {
        "summary": "امام جعفر صادق علیه السلام دعایی تعلیم فرمودند که هنگام دیدن فرد دچار معلولیت یا بلا، باید مخفیانه خوانده شود. این حدیث بر سپاسگزاری از نعمت سلامت و رعایت احساسات فرد مبتلا تأکید دارد.",
        "key_terms": {
          "عاهة": "معلولیت، نقص جسمانی",
          "بلاء": "بلا، آزمایش الهی",
          "عافاني": "به من عافیت داد، سلامت بخشید"
        },
        "seo_question": "هنگام دیدن فرد معلول یا مبتلا چه دعایی بخوانیم؟"
      },
      "id": {
        "summary": "Imam Ja'far al-Shadiq (a.s.) mengajarkan doa syukur yang harus dibaca secara diam-diam saat melihat orang yang menderita cacat atau musibah. Hadis ini menekankan rasa syukur atas kesehatan sekaligus menjaga perasaan orang yang menderita.",
        "key_terms": {
          "عاهة": "Cacat, kecacatan fisik",
          "بلاء": "Musibah, ujian ilahi",
          "عافاني": "Memberiku keselamatan, menganugerahkan kesehatan"
        },
        "seo_question": "Doa apa yang dibaca saat melihat orang cacat atau menderita dalam Islam?"
