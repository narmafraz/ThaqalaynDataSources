        "key_terms": {
          "العقل": "عقل، فہم و فراست",
          "التجرع": "گھونٹ پینا، غم برداشت کرنا",
          "الغصة": "غم، تکلیف، حلق میں گھونٹ",
          "مداهنة": "نرمی، مدارات، حکمت عملی"
