    "translations": {
      "en": {
        "summary": "The Prophet Muhammad foretells that a member of his progeny — understood by Shi'i tradition to be Imam Ali al-Rida (d. 203 AH / 818 CE), the eighth Imam — will be buried in the land of Khurasan (present-day Mashhad, Iran). He then states a powerful spiritual guarantee: any sincere believer who undertakes the pilgrimage to visit that grave will be granted Paradise by Allah and their body will be protected from Hellfire. This tradition has been one of the foundational textual supports for the practice of ziyarat (visitation) to the shrine of Imam al-Rida, which has been central to Shi'i devotional life for over a millennium.",
        "key_terms": {
          "بضعة مني": "A part of me — a prophetic expression denoting a blood descendant who shares the Prophet's spiritual and physical essence",
          "خراسان": "Khurasan — a historical region in northeastern Iran; the city of Tus (modern Mashhad) is where Imam al-Rida is buried",
          "أوجب": "Made mandatory / obligated — a strong legal term indicating a binding divine decree",
          "الجنة": "Paradise — the eternal abode of reward in the Hereafter",
          "النار": "The Fire — Hellfire, the abode of punishment"
        },
        "seo_question": "What did the Prophet Muhammad say about the virtue of visiting the grave of his descendant buried in Khurasan?"
      },
      "ur": {
        "summary": "نبی کریم نے پیشگوئی فرمائی کہ ان کی اولاد کا ایک فرد — شیعہ روایت کے مطابق امام علی الرضا — سرزمین خراسان (موجودہ مشہد) میں دفن ہوگا۔ جو مومن ان کی زیارت کرے اللہ اس کے لیے جنت واجب کر دے گا اور اس کے جسم کو آگ پر حرام کر دے گا۔",
        "key_terms": {
          "بضعة مني": "میرا ایک ٹکڑا — نبوی تعبیر جو خونی رشتے کی نشاندہی کرتی ہے",
          "خراسان": "خراسان — شمال مشرقی ایران کا تاریخی خطہ"
        },
        "seo_question": "نبی کریم نے خراسان میں دفن ہونے والے اپنے فرزند کی زیارت کے بارے میں کیا فرمایا؟"
      },
