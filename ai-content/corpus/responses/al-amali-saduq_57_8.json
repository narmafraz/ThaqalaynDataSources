    "translations": {
      "en": {
        "summary": "The Prophet Muhammad (SAWW) declared to Imam Ali (AS) that he is his inheritor. This statement, transmitted through a chain of Abbasid caliphs tracing back to the Prophet's cousin Ibn Abbas, affirms Ali's unique spiritual and temporal succession to the Prophet. In Shia tradition, this hadith is one of many establishing Ali's right to succeed the Prophet as the leader of the Muslim community.",
        "key_terms": {
          "وارث": "Inheritor, successor — refers to spiritual and temporal inheritance of prophetic knowledge and authority",
          "رسول الله": "The Messenger of God — title of Prophet Muhammad (SAWW)"
        },
        "seo_question": "What did the Prophet Muhammad say to Ali about being his inheritor?"
      },
      "ur": {
        "summary": "نبی کریم (صلی اللہ علیہ وآلہ) نے حضرت علی (علیہ السلام) کو فرمایا کہ آپ میرے وارث ہیں۔ یہ حدیث عباسی خلفاء کی سند سے ابن عباس تک پہنچتی ہے اور حضرت علی کی نبی کے جانشین کے طور پر فضیلت کو ثابت کرتی ہے۔",
        "key_terms": {
          "وارث": "وارث، جانشین — نبوی علم اور اختیار کی روحانی و دنیاوی میراث",
          "رسول الله": "رسول اللہ — حضرت محمد (صلی اللہ علیہ وآلہ) کا لقب"
        },
        "seo_question": "نبی کریم نے حضرت علی کو اپنا وارث ہونے کے بارے میں کیا فرمایا؟"
      },
      "tr": {
