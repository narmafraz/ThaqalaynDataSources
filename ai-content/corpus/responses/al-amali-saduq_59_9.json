    "translations": {
      "en": {
        "summary": "Imam Ja'far al-Sadiq (AS) taught the proper etiquette of sending blessings: when any prophet is mentioned, one should first send blessings upon Prophet Muhammad (SAWW) before blessing that prophet. This was taught to Muawiya ibn Ammar, a prominent companion, who had blessed another prophet directly and was corrected.",
        "key_terms": {
          "الصلاة": "Salawat, sending blessings upon the Prophet and his family",
          "الأنبياء": "The prophets of God from Adam to Muhammad"
        },
        "seo_question": "What is the etiquette of blessing the prophets in Shia Islam?"
      },
      "ur": {
        "summary": "امام جعفر صادق علیہ السلام نے صلوات بھیجنے کا آداب سکھایا: نبی کا ذکر ہو تو پہلے محمد صلی اللہ علیہ وآلہ پر صلوات بھیجیں۔",
        "key_terms": {
          "الصلاة": "صلوات، درود بھیجنا",
          "الأنبياء": "انبیاء کرام"
        },
        "seo_question": "انبیاء پر صلوات بھیجنے کا آداب کیا ہے؟"
      },
      "tr": {
        "summary": "İmam Cafer es-Sadık (a.s.) salat getirmenin âdâbını öğretti: peygamber anıldığında önce Hz. Muhammed'e salat getirilmelidir.",
        "key_terms": {
          "الصلاة": "Salavat, salat getirmek",
          "الأنبياء": "Peygamberler"
        },
        "seo_question": "Peygamberlere salat getirmenin âdâbı nedir?"
      },
      "fa": {
        "summary": "امام جعفر صادق علیه السلام آداب صلوات فرستادن را آموزش داد: هرگاه نام پیامبری ذکر شود ابتدا باید بر محمد صلوات فرستاد.",
        "key_terms": {
          "الصلاة": "صلوات، درود فرستادن",
          "الأنبياء": "انبیاء، پیامبران خدا"
        },
        "seo_question": "آداب صلوات فرستادن بر پیامبران چیست؟"
