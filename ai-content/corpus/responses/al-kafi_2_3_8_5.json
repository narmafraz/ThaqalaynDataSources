    "translations": {
      "en": {
        "summary": "Imam al-Sadiq (peace be upon him) was asked by Is'haq ibn Ammar whether it is better to recite the Quran from memory or while looking at the physical Mushaf. The Imam (AS) answered definitively that reciting while looking at the Mushaf is superior, adding the remarkable teaching that the very act of gazing at the Mushaf is itself an act of worship. This hadith is used by Shia jurisprudents to establish the spiritual merits of engaging with the written Quran.",
        "key_terms": {
          "ظهر القلب": "By heart/from memory; literally 'the back of the heart', an Arabic idiom for memorization",
          "المصحف": "The Mushaf — the physical written codex of the Quran; distinguished from the Quran as recitation",
          "عبادة": "An act of worship ('ibada); the term covers all acts of obedience and devotion to God"
        },
        "seo_question": "Is it better to recite the Quran from memory or while looking at the Mushaf?"
      },
      "ur": {
        "summary": "امام صادق علیہ السلام سے دریافت کیا گیا کہ قرآن کریم کو حفظ سے پڑھنا بہتر ہے یا مصحف دیکھ کر؟ آپ نے فرمایا کہ مصحف دیکھ کر پڑھنا افضل ہے اور یہ بھی کہ مصحف میں نظر ڈالنا خود عبادت ہے۔ اس حدیث سے مصحف کی فضیلت اور اس کے ادب کی اہمیت واضح ہوتی ہے۔",
        "key_terms": {
          "ظهر القلب": "زبانی حفظ؛ لغوی طور پر 'دل کی پشت' یعنی ازبر",
          "المصحف": "مصحف — قرآن کریم کی تحریری کتاب",
          "عبادة": "عبادت — اللہ کی اطاعت کا ہر عمل"
        },
        "seo_question": "قرآن کریم زبانی پڑھنا افضل ہے یا مصحف دیکھ کر؟"
      },
      "tr": {
        "summary": "İmam Sadık (a.s.) İshak ibn Ammar'a Kur'an'ı ezbere mi yoksa Mushaf'a bakarak mı okumanın daha üstün olduğu sorusunu yanıtladı. İmam, Mushaf'a bakarak okumanın daha faziletli olduğunu ve Mushaf'a bakmanın bizzat bir ibadet sayıldığını vurguladı.",
        "key_terms": {
          "ظهر القلب": "Ezber; lafzen 'kalbin arkası', Arapça'da ezbere anlamına gelen deyim",
          "المصحف": "Mushaf — Kur'an'ın yazılı nüshası",
          "عبادة": "İbadet — Allah'a her türlü kulluk"
        },
        "seo_question": "Kur'an'ı ezbere mi okumak daha mı faziletlidir, Mushaf'a bakarak mı?"
      },
      "fa": {
        "summary": "امام صادق علیه السلام در پاسخ به پرسشی از اسحاق بن عمار فرمودند که تلاوت قرآن با نگاه به مصحف برتر از تلاوت حفظی است و خود نگاه کردن به مصحف نیز عبادت محسوب می‌شود. این روایت مستند فقهی مهمی برای فضیلت تلاوت از روی مصحف در فقه شیعه است.",
        "key_terms": {
          "ظهر القلب": "از حفظ؛ به معنی تلاوت از روی حافظه",
          "المصحف": "مصحف — نسخه کتبی قرآن کریم",
          "عبادة": "عبادت — هر عمل اطاعت و بندگی"
        },
        "seo_question": "آیا تلاوت قرآن از روی مصحف برتر از تلاوت از حفظ است؟"
      },
      "id": {
        "summary": "Imam al-Shadiq (a.s.) menjawab pertanyaan Is'haq ibn Ammar bahwa membaca al-Quran sambil melihat mushaf lebih utama daripada membaca dari hafalan, dan menambahkan bahwa sekadar melihat mushaf pun merupakan ibadah.",
        "key_terms": {
          "ظهر القلب": "Di luar kepala; idiom Arab untuk hafalan",
          "المصحف": "Mushaf — naskah tertulis al-Quran",
          "عبادة": "Ibadah — setiap amalan pengabdian kepada Allah"
        },
        "seo_question": "Apakah membaca Quran dari hafalan atau melihat mushaf lebih utama?"
