    "translations": {
      "en": {
        "summary": "The Prophet Muhammad (S) warns that a servant of Allah may be held back from entering Paradise for up to a hundred years due to a single sin, all while watching his wives and brothers already enjoying its blessings. This hadith was transmitted through the chain of Imams from Imam Ali (AS), emphasizing the severity of sins and the anguish of being excluded from Paradise while seeing others within it.",
        "key_terms": {
          "ليحبس": "Will be imprisoned/held back - detained from entering Paradise",
          "ذنب": "Sin - a transgression that delays entry to Paradise",
          "الجنة": "Paradise - the ultimate reward for the believers"
        },
        "seo_question": "Can a person be delayed from entering Paradise because of sins?"
      },
      "ur": {
        "summary": "نبی کریم صلی اللہ علیہ وآلہ نے خبردار کیا کہ ایک گناہ کی وجہ سے بندے کو سو سال جنت سے روکا جا سکتا ہے۔",
        "key_terms": {
          "ليحبس": "محبوس رہے گا",
          "ذنب": "گناہ",
          "الجنة": "جنت"
        },
        "seo_question": "کیا گناہ کی وجہ سے جنت میں داخلے میں تاخیر ہو سکتی ہے؟"
      },
      "tr": {
        "summary": "Hz. Peygamber (s.a.a.) bir günahın kulu yüz yıl cennetten alıkoyabileceğini uyarmıştır.",
        "key_terms": {
          "ليحبس": "Hapsedilir",
          "ذنب": "Günah",
          "الجنة": "Cennet"
        },
        "seo_question": "Günah sebebiyle cennete giriş gecikir mi?"
      },
      "fa": {
        "summary": "پیامبر خدا (ص) هشدار داد که یک گناه می‌تواند بنده را صد سال از بهشت بازدارد.",
