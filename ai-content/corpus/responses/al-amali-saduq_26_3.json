    "translations": {
      "en": {
        "summary": "Al-Bazanti read a letter from Imam al-Rida (AS) which stated: 'Convey to my Shi'a that my visitation equals in the sight of Allah a thousand Hajj pilgrimages.' When al-Bazanti asked Imam al-Jawad (AS) — al-Rida's son — about this, he confirmed: 'Yes, by Allah, and a million Hajj pilgrimages for whoever visits him recognizing his right.' This hadith emphasizes the extraordinary spiritual reward of visiting Imam al-Rida's shrine with knowledge of his true status as a divinely appointed Imam.",
        "key_terms": {
          "زيارة": "Visitation (ziyara) — pilgrimage to an Imam's shrine",
          "عارفاً بحقه": "Recognizing his right — acknowledging his divinely appointed Imamate",
          "حجة": "Hajj pilgrimage — one of the five pillars of Islam"
        },
        "seo_question": "How many Hajj pilgrimages does visiting Imam al-Rida equal?"
      },
      "ur": {
        "summary": "بزنطی نے امام رضا (ع) کا خط پڑھا جس میں لکھا تھا: میرے شیعوں کو بتاؤ کہ میری زیارت اللہ کے نزدیک ہزار حج کے برابر ہے۔ جب بزنطی نے امام جواد (ع) سے پوچھا تو انہوں نے فرمایا: ہاں واللہ، اور دس لاکھ حج ان کے لیے جو اسے پہچان کر زیارت کرے۔",
        "key_terms": {
          "زيارة": "زیارت — امام کے مزار کی حاضری",
          "عارفاً بحقه": "اس کے حق کو پہچانتے ہوئے — الہٰی امامت کا اعتراف",
          "حجة": "حج — اسلام کے پانچ ارکان میں سے ایک"
        },
        "seo_question": "امام رضا کی زیارت کتنے حج کے برابر ہے؟"
      },
      "tr": {
        "summary": "Bezentî, İmam Rızâ'nın (a.s.) mektubunu okudu: 'Şîama ulaştır ki ziyaretim Allah katında bin hacca eşittir.' Bezentî, İmam Cevâd'a (a.s.) sorduğunda buyurdu: 'Evet, vallahi, hakkını bilerek ziyaret eden için bir milyon hac.'",
        "key_terms": {
          "زيارة": "Ziyaret — bir İmamın türbesine hac",
          "عارفاً بحقه": "Hakkını bilerek — İmam olarak tanıma",
          "حجة": "Hac — İslam'ın beş şartından biri"
        },
        "seo_question": "İmam Rızâ'yı ziyaret etmek kaç hacca eşittir?"
      },
      "fa": {
        "summary": "بزنطی نامه‌ی امام رضا (ع) را خواند: به شیعیان من ابلاغ کن که زیارت من نزد خداوند برابر با هزار حج است. وقتی بزنطی از امام جواد (ع) پرسید، فرمود: آری به خدا، و یک میلیون حج برای کسی که با شناخت حقش زیارت کند.",
        "key_terms": {
          "زيارة": "زیارت — حضور در بارگاه امام",
          "عارفاً بحقه": "با شناخت حق او — اعتراف به امامت",
          "حجة": "حج — یکی از پنج رکن اسلام"
        },
        "seo_question": "زیارت امام رضا معادل چند حج است؟"
      },
      "id": {
        "summary": "Al-Bazanthi membaca surat Imam al-Ridha (as): 'Sampaikan kepada Syiahku bahwa ziarahku setara di sisi Allah dengan seribu haji.' Ketika ditanya, Imam al-Jawad (as) menjawab: 'Ya, demi Allah, dan sejuta haji bagi yang mengunjunginya dengan mengenal haknya.'",
        "key_terms": {
          "زيارة": "Ziarah — kunjungan ke makam Imam",
          "عارفاً بحقه": "Mengenal haknya — mengakui Imamahnya",
          "حجة": "Haji — salah satu rukun Islam"
        },
        "seo_question": "Berapa haji yang setara dengan ziarah ke Imam al-Ridha?"
