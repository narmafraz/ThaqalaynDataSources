    "translations": {
      "en": {
        "summary": "The Prophet Muhammad (SAWW) taught that even the act of eating a small morsel of food that one finds — whether a crumb of bread or a single date — carries divine reward and forgiveness. This hadith, transmitted through the Imams of Ahl al-Bayt, was delivered in the context of early Muslim society where food scarcity was common and wasting even the smallest amount was viewed as ingratitude toward God's provision.",
        "key_terms": {
          "كسرة": "A crumb or broken piece of bread; refers to even the smallest portion of food",
          "تمرة": "A single date; dates were a staple food in early Arabian society",
          "يغفر": "Forgives; divine forgiveness granted as a reward for not wasting food"
        },
        "seo_question": "What is the reward for eating a crumb or date found on the ground in Islam?"
      },
      "ur": {
        "summary": "نبی کریم (صلی اللہ علیہ وآلہ) نے فرمایا کہ جو شخص زمین پر پڑا ہوا کھانے کا ایک چھوٹا سا ٹکڑا یا ایک کھجور بھی اٹھا کر کھا لے تو اللہ تعالیٰ اسے معاف فرما دیتا ہے۔ یہ حدیث خوراک کی قدر اور اسراف سے بچنے کی اہمیت پر زور دیتی ہے۔",
        "key_terms": {
          "كسرة": "ٹکڑا، روٹی کا چھوٹا سا حصہ",
          "تمرة": "ایک کھجور",
          "يغفر": "بخشش، اللہ کی مغفرت"
        },
        "seo_question": "اسلام میں زمین سے اٹھا کر کھانا کھانے کا کیا اجر ہے؟"
      },
      "tr": {
        "summary": "Hz. Peygamber (s.a.v.s.) yerde bulunan bir ekmek kırıntısı veya bir hurmanın bile yenmesi halinde Allah'ın bağışlayacağını bildirmiştir. Bu hadis, gıdaya saygı göstermenin ve israftan kaçınmanın önemini vurgular.",
        "key_terms": {
          "كسرة": "Kırıntı, küçük ekmek parçası",
          "تمرة": "Bir hurma",
          "يغفر": "Bağışlar, ilahi af"
        },
        "seo_question": "İslam'da yerde bulunan bir lokmayı yemenin sevabı nedir?"
      },
      "fa": {
        "summary": "پیامبر اکرم (صلی الله علیه وآله) فرمودند که هر کسی حتی تکه‌ای نان یا یک دانه خرما بیابد و بخورد، خداوند او را می‌بخشد. این حدیث بر اهمیت قدردانی از نعمت‌ها و پرهیز از اسراف تأکید دارد.",
        "key_terms": {
          "كسرة": "تکه نان، خرده‌ای از غذا",
          "تمرة": "یک دانه خرما",
          "يغفر": "می‌بخشد، آمرزش الهی"
        },
        "seo_question": "پاداش خوردن لقمه‌ای که بر زمین افتاده در اسلام چیست؟"
      },
      "id": {
        "summary": "Nabi Muhammad (saw) mengajarkan bahwa memakan remah roti atau sebutir kurma yang ditemukan akan mendatangkan pengampunan dari Allah. Hadis ini menekankan pentingnya menghargai nikmat makanan dan menghindari pemborosan.",
        "key_terms": {
          "كسرة": "Remah roti, sepotong kecil makanan",
          "تمرة": "Sebutir kurma",
          "يغفر": "Mengampuni, pengampunan ilahi"
