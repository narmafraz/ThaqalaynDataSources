    "translations": {
      "en": {
        "summary": "Imam Jafar al-Sadiq (AS) teaches that mastery over the self (nafs) in five emotional states -- desire, fear, craving, anger, and pleasure -- earns divine protection from Hellfire. This hadith, recorded in a session on Friday the 26th of Rabi al-Awwal 368 AH, identifies self-control as the key to salvation, a theme central to Islamic ethics and the Quranic description of the righteous.",
        "key_terms": {
          "نفس": "nafs -- the self or ego; in Islamic psychology, the lower self that must be disciplined through spiritual effort",
          "النار": "al-Nar -- the Hellfire; eschatological punishment from which self-control provides protection"
        },
        "seo_question": "What five emotional states must a Muslim control according to Imam al-Sadiq to be protected from Hellfire?"
      },
      "ur": {
        "summary": "امام جعفر صادق علیہ السلام فرماتے ہیں کہ پانچ جذباتی حالتوں میں نفس پر قابو رکھنے والے شخص کا جسم جہنم کی آگ پر حرام کر دیا جاتا ہے۔",
        "key_terms": {
          "نفس": "نفس — انسان کی اندرونی خواہشات جن پر قابو ضروری ہے",
          "النار": "آگ — جہنم جس سے ضبط نفس بچاتا ہے"
