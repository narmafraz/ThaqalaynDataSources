        "key_terms": {
          "الْبَعِيد": "دور — دور کے اہداف یا امور",
          "الشَّدِيد": "مشکل — زندگی کے سخت معاملات",
          "حِيلَة": "تدبیر — انسانی چالاکی",
          "مَكِيدَة": "مکاری — کوششوں سے بنائے گئے منصوبے",
          "قَدَّرَ": "مقدر — تقدیر الٰہی"
