    "translations": {
      "en": {
        "summary": "The Prophet Muhammad (SAWW) taught that keeping company with people of religion brings honour in both this world and the Hereafter. This hadith, delivered to his close companions and transmitted through the Ahl al-Bayt chain, emphasizes the importance of choosing righteous company. In early Islamic society, 'people of religion' (ahl al-din) referred to those devoted to learning, worship, and ethical conduct.",
        "key_terms": {
          "مجالسة": "Sitting with, keeping company, associating with — implies deliberate seeking of companionship",
          "أهل الدين": "People of religion — those devoted to religious learning and practice",
          "شرف": "Honour, nobility, distinction — both social and spiritual"
        },
        "seo_question": "What did the Prophet Muhammad say about sitting with religious people?"
      },
      "ur": {
        "summary": "حضور نبی اکرم صلی اللہ علیہ وآلہ نے فرمایا کہ دیندار لوگوں کی مجلس میں بیٹھنا دنیا اور آخرت دونوں میں عزت و شرف کا باعث ہے۔ یہ حدیث اہل بیت کے سنہری سلسلے سے مروی ہے اور نیک لوگوں کی صحبت اختیار کرنے کی ترغیب دیتی ہے۔",
        "key_terms": {
          "مجالسة": "ہم نشینی، مجلس میں بیٹھنا",
          "أهل الدين": "اہل دین — دین دار اور متقی لوگ",
          "شرف": "عزت، شرف، بزرگی"
        },
        "seo_question": "رسول اللہ صلی اللہ علیہ وآلہ نے اہل دین کی صحبت کے بارے میں کیا فرمایا؟"
      },
      "tr": {
        "summary": "Hz. Peygamber (s.a.v.s.) din ehliyle oturmanın hem dünya hem ahiret şerefi olduğunu beyan etmiştir. Bu hadis, Ehl-i Beyt silsilesiyle nakledilmiş olup, salih kimselerle sohbetin önemini vurgulamaktadır.",
        "key_terms": {
          "مجالسة": "Meclis, birlikte oturma, sohbet",
          "أهل الدين": "Din ehli — dindar ve takva sahibi kimseler",
          "شرف": "Şeref, onur, yücelik"
        },
        "seo_question": "Hz. Peygamber din ehliyle oturmak hakkında ne buyurmuştur?"
      },
      "fa": {
        "summary": "پیامبر اکرم صلی الله علیه وآله فرمودند که نشستن در مجلس اهل دین، موجب شرف و عزت هم در دنیا و هم در آخرت است. این حدیث از طریق سلسله اهل بیت نقل شده و بر اهمیت همنشینی با افراد صالح تأکید دارد.",
        "key_terms": {
          "مجالسة": "هم‌نشینی، نشستن در مجلس",
          "أهل الدين": "اهل دین — افراد متدین و پرهیزکار",
          "شرف": "شرف، عزت، افتخار"
        },
        "seo_question": "پیامبر اکرم درباره هم‌نشینی با اهل دین چه فرمودند؟"
      },
      "id": {
        "summary": "Nabi Muhammad (SAW) mengajarkan bahwa bermajlis dengan ahli agama membawa kehormatan di dunia dan akhirat. Hadis ini diriwayatkan melalui silsilah Ahlul Bait dan menekankan pentingnya memilih pergaulan yang saleh.",
        "key_terms": {
