    "translations": {
      "en": {
        "summary": "Imam Ali ibn Abi Talib (AS) made an observation about the nature of men and women, stating that what defines intelligence for women is expressed through their beauty, while what defines beauty for men is expressed through their intellect. This was a well-known aphorism in the Arab literary tradition, recorded through a chain reaching Imam al-Sadiq (AS) at a scholarly gathering in 368 AH. The saying highlights complementary qualities valued in each gender in classical Islamic society.",
        "key_terms": {
          "عقول": "Minds, intellects (plural of aql)",
          "جمال": "Beauty, comeliness",
          "النساء": "Women",
          "الرجال": "Men"
        },
        "seo_question": "What did Imam Ali say about the minds of women and the beauty of men?"
      },
      "ur": {
        "summary": "امام علی بن ابی طالب علیہ السلام نے مردوں اور عورتوں کی فطرت کے بارے میں فرمایا کہ عورتوں کی عقل ان کے حسن میں ظاہر ہوتی ہے اور مردوں کا حسن ان کی عقل میں ہے۔ یہ عرب ادبی روایت میں ایک مشہور قول ہے۔",
        "key_terms": {
          "عقول": "عقلیں، ذہانت (عقل کی جمع)",
          "جمال": "خوبصورتی، حسن",
          "النساء": "عورتیں",
          "الرجال": "مرد"
        },
        "seo_question": "امام علی علیہ السلام نے عورتوں کی عقل اور مردوں کے حسن کے بارے میں کیا فرمایا؟"
      },
      "tr": {
