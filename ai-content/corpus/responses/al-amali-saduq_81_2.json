    "translations": {
      "en": {
        "summary": "The Prophet Muhammad (s) declares that whoever observes a voluntary fast sincerely for the sake of Allah's reward will be granted obligatory forgiveness. This hadith, transmitted through the Imams of Ahl al-Bayt, highlights the immense spiritual value of voluntary (nafl) fasting, elevating it from a recommended act to one that guarantees divine pardon, incentivizing believers to fast beyond the obligatory days of Ramadan.",
        "key_terms": {
          "تطوعا": "Voluntarily (tatawwu'), a supererogatory act of worship beyond what is obligatory",
          "ابتغاء ثواب الله": "Seeking the reward of Allah, performing the act with pure intention for divine recompense",
          "المغفرة": "Forgiveness (al-maghfira), divine pardon of sins"
        },
        "seo_question": "What is the reward for voluntary fasting in Islam?"
      },
      "ur": {
        "summary": "نبی اکرم (ص) نے فرمایا کہ جو شخص اللہ کے ثواب کی خاطر نفلی روزہ رکھے، اس کی مغفرت واجب ہو جاتی ہے۔",
        "key_terms": {
          "تطوعا": "نفلی — فرض سے زائد عبادت",
          "المغفرة": "مغفرت — گناہوں کی معافی"
        },
        "seo_question": "اسلام میں نفلی روزے کا ثواب کیا ہے؟"
      },
      "tr": {
        "summary": "Hz. Peygamber (s), Allah'ın sevabını umarak nafile oruç tutanın bağışlanacağını öğretir.",
        "key_terms": {
          "تطوعا": "Nafile — farz dışı ibadet",
          "المغفرة": "Mağfiret — bağışlanma"
        },
        "seo_question": "İslam'da nafile orucun sevabı nedir?"
      },
      "fa": {
        "summary": "پیامبر اکرم (ص) فرمود هر کس به امید ثواب الهی روزه نافله بگیرد، مغفرت برایش واجب می‌شود.",
        "key_terms": {
          "تطوعا": "نافله — عبادت غیر واجب",
          "المغفرة": "مغفرت — آمرزش گناهان"
        },
        "seo_question": "پاداش روزه نافله در اسلام چیست؟"
      },
