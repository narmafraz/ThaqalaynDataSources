    "translations": {
      "en": {
        "summary": "The Prophet Muhammad (SAWW) teaches that the path to his intercession on the Day of Judgment is through loving and supporting his household (Ahl al-Bayt). This hadith, narrated through a chain reaching the 5th Imam al-Baqir (AS), establishes a direct connection between caring for the Prophet's family and earning his intercession in the Hereafter. The concept of tawassul (seeking means of approach to God through righteous intermediaries) is central to Shia theology.",
        "key_terms": {
          "التوسل": "Tawassul - seeking a means or way to approach God through intermediaries",
          "أهل بيتي": "My Ahl al-Bayt - the Prophet's household",
          "أشفع": "I intercede - the Prophet's intercession on behalf of believers",
          "يوم القيامة": "Day of Resurrection - the Day of Judgment"
        },
        "seo_question": "What did Prophet Muhammad say about connecting with Ahl al-Bayt and intercession on the Day of Resurrection?"
      },
      "ur": {
        "summary": "نبی کریم (ص) فرماتے ہیں کہ قیامت کے دن شفاعت کا راستہ اہل بیت سے محبت اور ان کی خدمت سے ہوکر گزرتا ہے۔",
        "key_terms": {
          "التوسل": "توسل - خدا تک رسائی کا ذریعہ",
          "أهل بيتي": "میرے اہل بیت - پیغمبر کا خاندان",
          "أشفع": "شفاعت کرنا",
          "يوم القيامة": "قیامت کا دن"
        },
        "seo_question": "اہل بیت سے صلہ رحمی اور شفاعت کے بارے میں رسول اللہ نے کیا فرمایا؟"
      },
      "tr": {
        "summary": "Hz. Peygamber (s.a.v.s.) kıyamet günü şefaatine ulaşmanın yolunun Ehl-i Beyt'e bağlanmak ve onları sevindirmek olduğunu öğretmektedir.",
        "key_terms": {
          "التوسل": "Tevessül - Allah'a yaklaşma vesilesi",
