        "key_terms": {
          "أستغفر الله": "استغفار — اللہ سے مغفرت طلب کرنا",
          "التوبة": "توبہ — اللہ کی طرف رجوع کرنا",
          "شعبان": "شعبان — اسلامی تقویم کا آٹھواں مہینہ",
