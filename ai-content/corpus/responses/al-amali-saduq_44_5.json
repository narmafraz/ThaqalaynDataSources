    "translations": {
      "en": {
        "summary": "Imam Ali (peace be upon him) teaches that those who are currently healthy and well have a greater need for supplication (du'a) than those already afflicted, because the healthy person is never safe from trials that may come at any time. This teaching was delivered to encourage the faithful to be proactive in seeking God's protection, recognizing that well-being is a temporary blessing that can change at any moment.",
        "key_terms": {
          "ابتلي": "To be tested, tried, or afflicted by God as a means of spiritual examination",
          "بلوى": "Trial, tribulation, or affliction sent as a test of faith",
          "المعافى": "One in a state of well-being, health, and safety from affliction",
          "الدعاء": "Supplication; calling upon God in prayer and entreaty",
          "البلاء": "Test, trial, affliction; can refer to both good and bad tests from God"
        },
        "seo_question": "Who is more in need of supplication: the one who is tested or the one who is well?"
      },
      "ur": {
        "summary": "امام علی (علیہ السلام) فرماتے ہیں کہ جو شخص عافیت میں ہے اس کو دعا کی زیادہ ضرورت ہے اس شخص سے جو پہلے سے آزمائش میں ہے، کیونکہ عافیت والا کسی بھی وقت آزمائش کا شکار ہو سکتا ہے۔",
        "key_terms": {
          "ابتلي": "آزمائش میں ڈالا جانا، مبتلا ہونا",
          "بلوى": "آزمائش، مصیبت، ابتلاء",
          "المعافى": "عافیت والا، صحت مند",
          "الدعاء": "دعا، اللہ سے مانگنا",
          "البلاء": "آزمائش، مصیبت"
        },
        "seo_question": "دعا کا زیادہ حقدار کون ہے: مصیبت زدہ یا عافیت والا؟"
      },
      "tr": {
        "summary": "Hz. Ali (a.s.) öğretir ki, sağlıkta olan kişinin duaya ihtiyacı, belaya uğramış kişiden daha fazladır; çünkü sağlıklı kişi her an imtihana maruz kalabilir.",
        "key_terms": {
          "ابتلي": "İmtihan edilmek, sınanmak",
          "بلوى": "İmtihan, bela, musibet",
          "المعافى": "Afiyet içinde olan, sağlıklı",
          "الدعاء": "Dua, Allah'a yakarış",
          "البلاء": "İmtihan, bela, sınav"
        },
        "seo_question": "Duaya daha layık olan kimdir: sınanan mı yoksa sağlıkta olan mı?"
      },
      "fa": {
        "summary": "امام علی (علیه السلام) می‌آموزد که کسی که در عافیت و سلامت است، بیش از شخص مبتلا به دعا نیاز دارد، زیرا انسان سالم هیچ‌گاه از آزمایش الهی ایمن نیست.",
        "key_terms": {
          "ابتلي": "آزمایش شدن، مبتلا شدن",
          "بلوى": "آزمایش، بلا، مصیبت",
          "المعافى": "شخص عافیت‌مند، سالم",
          "الدعاء": "دعا، نیایش",
          "البلاء": "بلا، آزمایش"
        },
        "seo_question": "چه کسی به دعا بیشتر نیازمند است: فرد مبتلا یا فرد سالم؟"
      },
      "id": {
        "summary": "Imam Ali (a.s.) mengajarkan bahwa orang yang dalam keadaan sehat dan sejahtera lebih membutuhkan doa daripada yang sedang diuji, karena orang yang sehat tidak pernah aman dari datangnya ujian kapan saja.",
        "key_terms": {
          "ابتلي": "Diuji, ditimpa cobaan",
          "بلوى": "Ujian, cobaan, musibah",
          "المعافى": "Orang yang sehat/sejahtera",
          "الدعاء": "Doa, permohonan kepada Allah",
          "البلاء": "Ujian, cobaan"
        },
        "seo_question": "Siapa yang lebih berhak berdoa: yang sedang diuji atau yang sedang sehat?"
      },
      "bn": {
        "summary": "ইমাম আলী (আ.) শিক্ষা দেন যে সুস্থ ব্যক্তি আক্রান্ত ব্যক্তির চেয়ে দোয়ার বেশি প্রয়োজন, কারণ সুস্থ ব্যক্তি কখনও পরীক্ষা থেকে নিরাপদ নন।",
